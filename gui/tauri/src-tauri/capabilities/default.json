{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "GenomeLens GUI Phase 0 permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "notification:default",
    "os:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "genomelens",
          "cmd": "genomelens",
          "args": true
        },
        {
          "name": "jcvi-genomelens",
          "cmd": "jcvi-genomelens",
          "args": true
        }
      ]
    },
    "shell:allow-open"
  ]
}
